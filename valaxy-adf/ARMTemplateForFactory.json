{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "valaxy-adf"
		},
		"AzureDataLakeStorage2_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'AzureDataLakeStorage2'"
		},
		"adv_gen2_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'adv_gen2'"
		},
		"az_adls_gen2_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'az_adls_gen2'"
		},
		"AzureDataLakeStorage2_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://valaxystrgaccv2.dfs.core.windows.net/"
		},
		"adv_gen2_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://valaxystrgaccv2.dfs.core.windows.net/"
		},
		"az_adls_gen2_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://valaxystrgaccv2.dfs.core.windows.net/"
		},
		"az_kv_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://valaxy-kv.vault.azure.net/"
		},
		"ds_azsql_inc_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "valaxy-training.database.windows.net"
		},
		"ds_azsql_inc_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "free-sql-db-0140331"
		},
		"ds_azsql_inc_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "valaxy-training"
		},
		"git_http_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://raw.githubusercontent.com/"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "[concat(parameters('factoryName'), '/Incremental')]",
			"type": "Microsoft.DataFactory/factories/pipelines",
			"apiVersion": "2018-06-01",
			"properties": {
				"activities": [
					{
						"name": "Water_Mark",
						"type": "Lookup",
						"dependsOn": [],
						"policy": {
							"timeout": "0.12:00:00",
							"retry": 0,
							"retryIntervalInSeconds": 30,
							"secureOutput": false,
							"secureInput": false
						},
						"userProperties": [],
						"typeProperties": {
							"source": {
								"type": "AzureSqlSource",
								"queryTimeout": "02:00:00",
								"partitionOption": "None"
							},
							"dataset": {
								"referenceName": "ds_azsql_inc",
								"type": "DatasetReference",
								"parameters": {
									"table_name": "water_mark",
									"schema_name": "emp"
								}
							},
							"firstRowOnly": false
						}
					},
					{
						"name": "ForEach1",
						"type": "ForEach",
						"dependsOn": [
							{
								"activity": "Water_Mark",
								"dependencyConditions": [
									"Succeeded"
								]
							}
						],
						"userProperties": [],
						"typeProperties": {
							"items": {
								"value": "@activity('Water_Mark').output.value",
								"type": "Expression"
							},
							"isSequential": false,
							"activities": [
								{
									"name": "Max_Value",
									"type": "Lookup",
									"dependsOn": [],
									"policy": {
										"timeout": "0.12:00:00",
										"retry": 0,
										"retryIntervalInSeconds": 30,
										"secureOutput": false,
										"secureInput": false
									},
									"userProperties": [],
									"typeProperties": {
										"source": {
											"type": "AzureSqlSource",
											"sqlReaderQuery": {
												"value": "select max(@{item().delta_col}) as max_value from @{item().table_schema}.@{item().table_name}",
												"type": "Expression"
											},
											"queryTimeout": "02:00:00",
											"partitionOption": "None"
										},
										"dataset": {
											"referenceName": "ds_azsql_inc",
											"type": "DatasetReference",
											"parameters": {
												"table_name": "''",
												"schema_name": "''"
											}
										}
									}
								},
								{
									"name": "Copy data1",
									"type": "Copy",
									"dependsOn": [
										{
											"activity": "Max_Value",
											"dependencyConditions": [
												"Succeeded"
											]
										}
									],
									"policy": {
										"timeout": "0.12:00:00",
										"retry": 0,
										"retryIntervalInSeconds": 30,
										"secureOutput": false,
										"secureInput": false
									},
									"userProperties": [],
									"typeProperties": {
										"source": {
											"type": "AzureSqlSource",
											"sqlReaderQuery": {
												"value": "select * from @{item().table_schema}.@{item().table_name}\nwhere @{item().delta_col} > '@{item().last_loaded_date}'",
												"type": "Expression"
											},
											"queryTimeout": "02:00:00",
											"partitionOption": "None"
										},
										"sink": {
											"type": "DelimitedTextSink",
											"storeSettings": {
												"type": "AzureBlobFSWriteSettings"
											},
											"formatSettings": {
												"type": "DelimitedTextWriteSettings",
												"quoteAllText": true,
												"fileExtension": ".csv"
											}
										},
										"enableStaging": false,
										"translator": {
											"type": "TabularTranslator",
											"typeConversion": true,
											"typeConversionSettings": {
												"allowDataTruncation": true,
												"treatBooleanAsNumber": false
											}
										}
									},
									"inputs": [
										{
											"referenceName": "ds_azsql_inc",
											"type": "DatasetReference",
											"parameters": {
												"table_name": "''",
												"schema_name": "''"
											}
										}
									],
									"outputs": [
										{
											"referenceName": "az_adlsgen2",
											"type": "DatasetReference",
											"parameters": {
												"folder_name": {
													"value": "@concat(item().folder_name,formatDateTime(utcNow(), 'yyyy/MM/dd hh/mm/ss'))",
													"type": "Expression"
												},
												"file_name": {
													"value": "@concat(item().table_name,'.csv')",
													"type": "Expression"
												}
											}
										}
									]
								},
								{
									"name": "Update_Wark_Mark",
									"type": "SqlServerStoredProcedure",
									"dependsOn": [
										{
											"activity": "Copy data1",
											"dependencyConditions": [
												"Succeeded"
											]
										}
									],
									"policy": {
										"timeout": "0.12:00:00",
										"retry": 0,
										"retryIntervalInSeconds": 30,
										"secureOutput": false,
										"secureInput": false
									},
									"userProperties": [],
									"typeProperties": {
										"storedProcedureName": "[[dbo].[usp_watermark_update]",
										"storedProcedureParameters": {
											"last_loaded_value": {
												"value": {
													"value": "@activity('Max_Value').output.firstRow.max_value",
													"type": "Expression"
												},
												"type": "String"
											},
											"table_name": {
												"value": {
													"value": "@item().table_name",
													"type": "Expression"
												},
												"type": "String"
											}
										}
									},
									"linkedServiceName": {
										"referenceName": "ds_azsql_inc",
										"type": "LinkedServiceReference"
									}
								}
							]
						}
					}
				],
				"policy": {
					"elapsedTimeMetric": {}
				},
				"annotations": [],
				"lastPublishTime": "2026-05-30T04:09:07Z"
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/datasets/ds_azsql_inc')]",
				"[concat(variables('factoryId'), '/datasets/az_adlsgen2')]",
				"[concat(variables('factoryId'), '/linkedServices/ds_azsql_inc')]"
			]
		},
		{
			"name": "[concat(parameters('factoryName'), '/adv_gen2_ds')]",
			"type": "Microsoft.DataFactory/factories/datasets",
			"apiVersion": "2018-06-01",
			"properties": {
				"linkedServiceName": {
					"referenceName": "adv_gen2",
					"type": "LinkedServiceReference"
				},
				"parameters": {
					"p_sink_folder": {
						"type": "String"
