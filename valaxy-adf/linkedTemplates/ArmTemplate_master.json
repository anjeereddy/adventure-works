{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "valaxy-adf"
		},
		"AzureDataLakeStorage2_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'AzureDataLakeStorage2'"
		},
		"adv_gen2_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'adv_gen2'"
		},
		"az_adls_gen2_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'az_adls_gen2'"
		},
		"AzureDataLakeStorage2_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://valaxystrgaccv2.dfs.core.windows.net/"
		},
		"adv_gen2_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://valaxystrgaccv2.dfs.core.windows.net/"
		},
		"az_adls_gen2_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://valaxystrgaccv2.dfs.core.windows.net/"
		},
		"az_kv_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://valaxy-kv.vault.azure.net/"
		},
		"ds_azsql_inc_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "valaxy-training.database.windows.net"
		},
		"ds_azsql_inc_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "free-sql-db-0140331"
		},
		"ds_azsql_inc_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "valaxy-training"
		},
		"git_http_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://raw.githubusercontent.com/"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "valaxy-adf_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"AzureDataLakeStorage2_accountKey": {
						"value": "[parameters('AzureDataLakeStorage2_accountKey')]"
					},
					"adv_gen2_accountKey": {
						"value": "[parameters('adv_gen2_accountKey')]"
					},
					"az_adls_gen2_accountKey": {
						"value": "[parameters('az_adls_gen2_accountKey')]"
					},
					"AzureDataLakeStorage2_properties_typeProperties_url": {
						"value": "[parameters('AzureDataLakeStorage2_properties_typeProperties_url')]"
					},
					"adv_gen2_properties_typeProperties_url": {
						"value": "[parameters('adv_gen2_properties_typeProperties_url')]"
					},
					"az_adls_gen2_properties_typeProperties_url": {
						"value": "[parameters('az_adls_gen2_properties_typeProperties_url')]"
					},
					"az_kv_properties_typeProperties_baseUrl": {
						"value": "[parameters('az_kv_properties_typeProperties_baseUrl')]"
					},
					"git_http_properties_typeProperties_url": {
						"value": "[parameters('git_http_properties_typeProperties_url')]"
					},
					"ds_azsql_inc_properties_typeProperties_server": {
						"value": "[parameters('ds_azsql_inc_properties_typeProperties_server')]"
					},
					"ds_azsql_inc_properties_typeProperties_database": {
						"value": "[parameters('ds_azsql_inc_properties_typeProperties_database')]"
					},
					"ds_azsql_inc_properties_typeProperties_userName": {
						"value": "[parameters('ds_azsql_inc_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}